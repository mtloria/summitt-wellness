---
import finishPhoto from '../assets/Finishing Photo Hyrox 2025.jpg';
---

<section class="about" id="about">
  <div class="container">
    <div class="about-grid">
      <!-- Photo column -->
      <div class="about-photos">
        <div class="photo-main-wrap">
          <img
            src={finishPhoto.src}
            alt="Ryan Summitt at the HYROX Atlanta finish line"
            class="photo-main"
            loading="lazy"
          />
          <div class="photo-accent-bar"></div>
        </div>
      </div>

      <!-- Content column -->
      <div class="about-content">
        <span class="eyebrow">Meet Your Coach</span>
        <h2 class="section-title about-title">
          Coaching Built on<br />Clinical Expertise.
        </h2>
        <p class="about-body">
          Ryan Summitt, PT, DPT, OCS, CSCS, is a fitness coach, physical therapist, and strength
          and conditioning specialist with nearly two decades of experience helping people move
          better, get stronger, and stay active for life. His coaching career began in 2008 while
          studying at DePauw University, where he worked as a personal trainer and developed a
          passion for helping others achieve their fitness goals.
        </p>
        <p class="about-body">
          What sets Ryan apart is his unique combination of fitness coaching and clinical expertise.
          As a Doctor of Physical Therapy, Board-Certified Orthopedic Clinical Specialist (OCS), and
          Certified Strength and Conditioning Specialist (CSCS), he understands both how to maximize
          performance and how to navigate injuries safely. For the past 12 years, Ryan has focused on
          helping active individuals bridge the gap between rehabilitation and fitness, guiding them
          from injury recovery back to the activities they love with confidence.
        </p>
        <p class="about-body">
          Ryan believes that fitness should enhance every aspect of life, not just performance in the
          gym. Whether working with athletes, busy professionals, or active adults, his approach
          combines evidence-based training, movement optimization, and sustainable habits to help
          clients build strength, resilience, and longevity.
        </p>

        <!-- Credential badges -->
        <div class="cred-badges">
          {['PT, DPT', 'OCS', 'CSCS', 'TPI Certified'].map((c) => (
            <span class="cred-badge">{c}</span>
          ))}
        </div>

        <!-- Highlights -->
        <div class="highlights">
          <div class="highlight-item">
            <span class="highlight-number">18+</span>
            <span class="highlight-label">Years of coaching and clinical experience</span>
          </div>
          <p class="highlight-personal">
            Outside of coaching, Ryan enjoys spending time with his wife and three children, caring
            for their two Labrador Retrievers, and pursuing his own athletic challenges — from trail
            races and a Grand Canyon Rim-to-Rim-to-Rim crossing to HYROX competitions and improving
            his golf game.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background-color: var(--c-bg);
    padding: 100px 0;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 72px;
    align-items: start;
  }

  /* ─── Photos ─────────────────────────────────── */
  .about-photos {
    position: relative;
  }

  .photo-main-wrap {
    position: relative;
  }

  .photo-main {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lg);
  }

  .photo-accent-bar {
    position: absolute;
    top: -10px;
    left: -10px;
    width: 60px;
    height: 60px;
    border-top: 4px solid var(--c-secondary);
    border-left: 4px solid var(--c-secondary);
    border-radius: 2px 0 0 0;
    pointer-events: none;
  }

  /* ─── Content ────────────────────────────────── */
  .about-content {
    padding-top: 8px;
  }

  .about-title {
    font-size: clamp(2.25rem, 4vw, 3rem);
    margin-bottom: 28px;
  }

  .about-body {
    font-family: var(--f-body);
    font-size: 1rem;
    line-height: 1.8;
    color: var(--c-text-muted);
    margin-bottom: 18px;
  }

  .cred-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 28px 0;
  }

  .cred-badge {
    font-family: var(--f-ui);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c-secondary-dark);
    background: rgba(192, 139, 62, 0.1);
    border: 1px solid rgba(192, 139, 62, 0.25);
    padding: 5px 12px;
    border-radius: 100px;
  }

  .highlights {
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-top: 1px solid var(--c-border);
    padding-top: 28px;
  }

  .highlight-item {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }

  .highlight-number {
    font-family: var(--f-display);
    font-weight: 800;
    font-size: 1.875rem;
    color: var(--c-secondary);
    line-height: 1;
    min-width: 56px;
    flex-shrink: 0;
  }

  .highlight-label {
    font-family: var(--f-body);
    font-size: 0.9rem;
    color: var(--c-text-muted);
    line-height: 1.5;
  }

  .highlight-personal {
    font-family: var(--f-body);
    font-size: 0.9rem;
    line-height: 1.75;
    color: var(--c-text-muted);
    font-style: italic;
  }

  /* ─── Responsive ─────────────────────────────── */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .photo-main {
      aspect-ratio: 3 / 2;
      object-position: center 30%;
    }
  }

  @media (max-width: 600px) {
    .about {
      padding: 72px 0;
    }
  }
</style>
