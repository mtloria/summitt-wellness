---
import sledPull from '../assets/Hyrox 2025 Sled Pull Photo.jpg';
import sledPush from '../assets/Hyrox 2025 Sled Push Photo.jpg';
import lunge from '../assets/Hyrox 2025 Walking Lunge.jpg';
---

<section class="gallery" aria-label="Ryan in competition at HYROX Atlanta 2025">
  <div class="gallery-grid">
    <div class="gallery-item gallery-item--tall">
      <img
        src={sledPull.src}
        alt="Ryan Summitt pulling a sled rope at HYROX Atlanta"
        class="gallery-img"
        loading="lazy"
      />
      <div class="gallery-overlay">
        <span class="gallery-caption">HYROX Atlanta 2025</span>
      </div>
    </div>
    <div class="gallery-item gallery-item--wide">
      <img
        src={sledPush.src}
        alt="Ryan Summitt pushing a weighted sled at HYROX Atlanta"
        class="gallery-img"
        loading="lazy"
      />
      <div class="gallery-overlay">
        <span class="gallery-caption">Sled Push</span>
      </div>
    </div>
    <div class="gallery-item gallery-item--portrait">
      <img
        src={lunge.src}
        alt="Ryan Summitt performing walking lunges with a sandbag at HYROX Atlanta"
        class="gallery-img gallery-img--lunge"
        loading="lazy"
      />
      <div class="gallery-overlay">
        <span class="gallery-caption">Sandbag Lunge</span>
      </div>
    </div>
  </div>

  <div class="gallery-tagline">
    <p class="gallery-quote">
      &ldquo;Ryan doesn&rsquo;t just coach it &mdash; he lives it.&rdquo;
    </p>
    <p class="gallery-event">HYROX Atlanta 2025 &middot; Finish time 1:15:56</p>
  </div>
</section>

<style>
  .gallery {
    background-color: var(--c-primary-dark);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto;
    height: clamp(400px, 60vw, 680px);
    overflow: hidden;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
  }

  .gallery-item--tall {
    grid-column: 1;
    grid-row: 1 / 3;
  }

  .gallery-item--wide {
    grid-column: 2;
    grid-row: 1;
  }

  .gallery-item--portrait {
    grid-column: 2 / 4;
    grid-row: 2;
  }

  .gallery-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.5s ease;
  }

  .gallery-img--lunge {
    object-position: center 20%;
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.04);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(15, 26, 39, 0.7) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 16px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-caption {
    font-family: var(--f-ui);
    font-weight: 600;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
  }

  .gallery-tagline {
    padding: 32px 24px;
    text-align: center;
  }

  .gallery-quote {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: rgba(255, 255, 255, 0.85);
    font-style: italic;
    margin-bottom: 6px;
  }

  .gallery-event {
    font-family: var(--f-ui);
    font-size: 0.8125rem;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }

  @media (max-width: 760px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }

    .gallery-item--tall {
      grid-column: 1;
      grid-row: 1 / 3;
      min-height: 320px;
    }

    .gallery-item--wide {
      grid-column: 2;
      grid-row: 1;
      min-height: 155px;
    }

    .gallery-item--portrait {
      grid-column: 2;
      grid-row: 2;
      min-height: 155px;
    }

    .gallery-overlay {
      opacity: 1;
    }
  }
</style>
