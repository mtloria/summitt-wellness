---
const credentials = [
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>`,
    label: '18+ Years Experience',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    label: 'Doctor of Physical Therapy',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/></svg>`,
    label: 'Board-Certified OCS',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2H9z"/></svg>`,
    label: 'CSCS Certified',
  },
  {
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
    label: 'TPI Golf Certified',
  },
];
---

<div class="creds-bar">
  <div class="container">
    <div class="creds-list">
      {credentials.map((c, i) => (
        <>
          <div class="cred-item">
            <span class="cred-icon" set:html={c.icon} />
            <span class="cred-label">{c.label}</span>
          </div>
          {i < credentials.length - 1 && <span class="cred-sep" aria-hidden="true">&bull;</span>}
        </>
      ))}
    </div>
  </div>
</div>

<style>
  .creds-bar {
    background-color: var(--c-primary-dark);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 20px 0;
  }

  .creds-list {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    row-gap: 12px;
  }

  .cred-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: rgba(255, 255, 255, 0.72);
  }

  .cred-icon {
    display: flex;
    align-items: center;
    color: var(--c-secondary-light);
    flex-shrink: 0;
  }

  .cred-label {
    font-family: var(--f-ui);
    font-weight: 500;
    font-size: 0.8125rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .cred-sep {
    color: rgba(255, 255, 255, 0.2);
    font-size: 0.5rem;
  }

  @media (max-width: 600px) {
    .cred-sep {
      display: none;
    }

    .creds-list {
      gap: 8px 16px;
    }
  }
</style>
