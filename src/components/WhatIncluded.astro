---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01M12 14h.01M16 14h.01M8 18h.01M12 18h.01"/></svg>`,
    title: 'Individualized Daily Workouts',
    body: 'Every day of the week planned around your goals, schedule, and available equipment. No guessing — just show up and execute.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
    title: 'Trainerize App Access',
    body: 'Your complete coaching hub — workouts, exercise videos, progress logs, habit tracking, and direct messaging all in one place.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
    title: 'Rehab & Prehab Programming',
    body: "Targeted exercises based on your injury history and movement assessment — keeping you healthy so nothing slows you down.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: 'Nutrition Guidance',
    body: 'Practical nutrition habits that support your goals — whether improving body composition, enhancing performance, or building a healthier lifestyle.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
    title: 'Unlimited Coaching Support',
    body: "Direct access to Ryan whenever you need it. Questions about a movement, need a modification, want feedback — he's there.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>`,
    title: 'Progress Tracking & Adjustments',
    body: 'Ongoing program evolution based on your results and feedback. Your program grows with you, never staying stagnant.',
  },
];
---

<section class="included" id="coaching">
  <div class="container">
    <div class="included-header">
      <span class="eyebrow">What You&rsquo;ll Get</span>
      <h2 class="section-title included-title">
        Everything You Need.<br />Nothing You Don&rsquo;t.
      </h2>
      <p class="included-sub">
        One program. Everything built around you &mdash; from day-one planning to ongoing
        adjustments as you progress.
      </p>
    </div>

    <div class="features-grid">
      {features.map((f) => (
        <div class="feature-card">
          <div class="feature-icon" set:html={f.icon} />
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-body">{f.body}</p>
        </div>
      ))}
    </div>

    <div class="included-cta">
      <button class="btn btn-gold quiz-trigger" id="coaching-quiz-btn">
        Start with the Fit Quiz
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
      <p class="included-note">Free 20-minute consultation call &middot; No commitment required</p>
    </div>
  </div>
</section>

<script>
  document.getElementById('coaching-quiz-btn')?.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('open-quiz'));
  });
</script>

<style>
  .included {
    background-color: var(--c-surface);
    padding: 100px 0;
  }

  .included-header {
    max-width: 600px;
    margin-bottom: 60px;
  }

  .included-title {
    font-size: clamp(2.25rem, 4vw, 3rem);
    margin-bottom: 18px;
  }

  .included-sub {
    font-family: var(--f-body);
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--c-text-muted);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 56px;
  }

  .feature-card {
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: 10px;
    padding: 28px 26px;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }

  .feature-card:hover {
    box-shadow: var(--shadow-md);
    border-color: rgba(192, 139, 62, 0.3);
    transform: translateY(-2px);
  }

  .feature-icon {
    color: var(--c-secondary);
    margin-bottom: 16px;
    display: flex;
  }

  .feature-title {
    font-family: var(--f-ui);
    font-weight: 700;
    font-size: 1rem;
    color: var(--c-primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .feature-body {
    font-family: var(--f-body);
    font-size: 0.9rem;
    line-height: 1.72;
    color: var(--c-text-muted);
  }

  .included-cta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .included-note {
    font-family: var(--f-body);
    font-size: 0.875rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 900px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .included {
      padding: 72px 0;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
