---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import Hero from '../components/Hero.astro';
import CredentialsBar from '../components/CredentialsBar.astro';
import About from '../components/About.astro';
import TeamSection from '../components/TeamSection.astro';
import WhatIncluded from '../components/WhatIncluded.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FAQ from '../components/FAQ';
import ContactCTA from '../components/ContactCTA.astro';
import Footer from '../components/Footer.astro';
import IntakeQuiz from '../components/IntakeQuiz';

import logoSrc from '../assets/Horizontal Logo Transparent.png';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout>
  <Nav logoSrc={logoSrc.src} base={base} client:load />
  <main>
    <Hero />
    <CredentialsBar />
    <About />
    <TeamSection />
    <WhatIncluded />
    <HowItWorks />
    <FAQ client:visible />
    <ContactCTA />
  </main>
  <Footer />
  <IntakeQuiz client:load />
</Layout>
