---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Summitt Wellness | Expert Online Coaching | Ryan Summitt, PT, DPT',
  description =
    'Evidence-based online fitness coaching from Ryan Summitt, Doctor of Physical Therapy, OCS, CSCS, and TPI certified. Train smarter, move better, and perform for life.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}/favicon.ico`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}/apple-touch-icon.png`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Fonts: Barlow Condensed (display) · Barlow (UI) · Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700;800;900&family=Barlow:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ─── Design Tokens ────────────────────────────────────────────── */
  :root {
    --c-primary: #1c2f3e;
    --c-primary-light: #2a4459;
    --c-primary-dark: #0f1a27;
    --c-secondary: #c08b3e;
    --c-secondary-light: #d4a55a;
    --c-secondary-dark: #9b6e2c;
    --c-bg: #f7f4ef;
    --c-surface: #ffffff;
    --c-border: #e2ddd8;
    --c-text: #1c2f3e;
    --c-text-muted: #607182;

    --f-display: 'Barlow Condensed', sans-serif;
    --f-ui: 'Barlow', sans-serif;
    --f-body: 'Inter', sans-serif;

    --radius: 6px;
    --shadow-sm: 0 1px 4px rgba(0, 0, 0, 0.07);
    --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.1);
    --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.13);
  }

  /* ─── Reset ────────────────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--f-body);
    background-color: var(--c-bg);
    color: var(--c-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  /* ─── Layout Utilities ─────────────────────────────────────────── */
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ─── Typography Utilities ─────────────────────────────────────── */
  .eyebrow {
    font-family: var(--f-ui);
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--c-secondary);
    display: inline-block;
    margin-bottom: 14px;
  }

  .eyebrow-light {
    color: var(--c-secondary-light);
  }

  .section-title {
    font-family: var(--f-display);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--c-primary);
  }

  .section-title-light {
    color: #ffffff;
  }

  /* ─── Button Utilities ─────────────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--f-ui);
    font-weight: 600;
    font-size: 0.8125rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 4px;
    padding: 14px 30px;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s, box-shadow 0.2s, transform 0.15s, border-color 0.2s,
      color 0.2s;
    white-space: nowrap;
  }

  .btn-gold {
    color: #ffffff;
    background-color: var(--c-secondary);
  }

  .btn-gold:hover {
    background-color: var(--c-secondary-dark);
    box-shadow: 0 6px 20px rgba(192, 139, 62, 0.35);
    transform: translateY(-1px);
  }

  .btn-outline-white {
    color: rgba(255, 255, 255, 0.88);
    background: transparent;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }

  .btn-outline-white:hover {
    border-color: rgba(255, 255, 255, 0.88);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
  }

  .btn-outline-dark {
    color: var(--c-primary);
    background: transparent;
    border: 1.5px solid var(--c-primary);
  }

  .btn-outline-dark:hover {
    background: var(--c-primary);
    color: #ffffff;
  }
</style>
